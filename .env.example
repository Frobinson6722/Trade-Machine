# LLM Provider API Keys
OPENAI_API_KEY=your_openai_api_key
ANTHROPIC_API_KEY=your_anthropic_api_key
GOOGLE_API_KEY=your_google_api_key

# Robinhood Credentials
ROBINHOOD_USERNAME=your_robinhood_email
ROBINHOOD_PASSWORD=your_robinhood_password
ROBINHOOD_MFA_CODE=your_mfa_code_or_totp_secret

# Data Provider API Keys
CRYPTOPANIC_API_KEY=your_cryptopanic_api_key

# Backend
AUTH_TOKEN=your_secret_auth_token
DATABASE_URL=sqlite+aiosqlite:///./trade_machine.db

# Engine Config
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o
CYCLE_INTERVAL_SECONDS=900
DEFAULT_TRADING_PAIRS=BTC-USD,ETH-USD
