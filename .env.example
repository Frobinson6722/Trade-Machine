# Anthropic API Key (required)
ANTHROPIC_API_KEY=your_anthropic_api_key

# Claude Model (optional overrides)
LLM_MODEL=claude-sonnet-4-20250514
DEEP_THINK_MODEL=claude-sonnet-4-20250514
QUICK_THINK_MODEL=claude-haiku-4-5-20251001

# Robinhood Credentials (needed for live trading only)
ROBINHOOD_USERNAME=your_robinhood_email
ROBINHOOD_PASSWORD=your_robinhood_password
ROBINHOOD_MFA_CODE=your_mfa_code_or_totp_secret

# Data Provider API Keys (optional)
CRYPTOPANIC_API_KEY=your_cryptopanic_api_key

# Engine Config
CYCLE_INTERVAL_SECONDS=900
DEFAULT_TRADING_PAIRS=BTC-USD,ETH-USD
